# ═══════════════════════════════════════════════════════════════════════════
# Garamatic Integration Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and customize for your local setup.
# ═══════════════════════════════════════════════════════════════════════════

# SendGrid (optional - mailing service works without it for testing)
SENDGRID_API_KEY=SG.your-test-key
SENDGRID_FROM_EMAIL=test@garamatic.io
SENDGRID_FROM_NAME=Garamatic Test

# Gatekeeper API Key (for ingestion endpoint tests)
GATEKEEPER_API_KEY=masala-test-key

# Agentic Service API Key
AGENTIC_API_KEY=garamatic-agentic-secret-key

# Grafana Admin Password
GRAFANA_ADMIN_PASSWORD=admin

# OpenAI / Ollama (optional - agentic service uses Ollama by default)
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_API_KEY=ollama

# Backup Directory
BACKUP_DIR=./backups

# Cloudflare Tunnel (optional - for remote access)
# Get tunnel ID: cloudflared tunnel list
# CLOUDFLARE_TUNNEL_ID=your-tunnel-id
# CLOUDFLARE_DOMAIN=your-domain.com
