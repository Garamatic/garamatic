# ═══════════════════════════════════════════════════════════════════════════
# Garamatic Integration Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and customize for your local setup.
# ═══════════════════════════════════════════════════════════════════════════

# SendGrid (optional - mailing service works without it for testing)
SENDGRID_API_KEY=SG.your-test-key
SENDGRID_FROM_EMAIL=test@garamatic.io
SENDGRID_FROM_NAME=Garamatic Test

# Gatekeeper API Key (for ingestion endpoint tests)
GATEKEEPER_API_KEY=masala-test-key

# Grafana (if using monitoring stack from masala-web)
GRAFANA_ADMIN_PASSWORD=admin
