# ═══════════════════════════════════════════════════════════════════════════
# Garamatic Integration Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and customize for your local setup.
# ═══════════════════════════════════════════════════════════════════════════

# ── Demo: leave SENDGRID_API_KEY empty — mailing-service auto-falls back to Mailhog ──
# Set a real key only for live email delivery in production.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=demo@garamatic.io
SENDGRID_FROM_NAME=Garamatic Demo

# Agentic Service API Key — shared across ticket-masala, agentic-service, and seeder.
# The default matches all compose service defaults; change consistently if you override.
AGENTIC_API_KEY=garamatic-agentic-secret-key

# Grafana Admin Password
GRAFANA_ADMIN_PASSWORD=admin

# LLM — the demo stack starts a local llama.cpp container automatically (no API key needed).
# Set OPENAI_API_KEY only if you want to use the real OpenAI API instead of the local model.
OPENAI_API_KEY=

# Backup Directory
BACKUP_DIR=./backups

# ═─────────────────────────────────────────────────────────────────────────
# Cloudflare Tunnel — Locally Managed Tunnel (recommended for remote access)
# ═─────────────────────────────────────────────────────────────────────────
# Setup steps:
#   1. Install cloudflared: https://developers.cloudflare.com/cloudflare-one/connections/connect-networks/downloads/
#   2. Authenticate: cloudflared tunnel login
#   3. Create tunnel: cloudflared tunnel create garamatic
#   4. Add to .env:  CLOUDFLARE_TUNNEL_ID=<tunnel-id>
#   5. Add to .env:  CLOUDFLARE_DOMAIN=your-domain.com
#   6. Run:          make tunnel-setup   # Generates config + copies credentials
#   7. Run:          make tunnel-up
#   8. Add DNS:      cloudflared tunnel route dns <id> <subdomain>
#
# CLOUDFLARE_TUNNEL_ID=your-tunnel-id
# CLOUDFLARE_DOMAIN=garamatic.example.com
