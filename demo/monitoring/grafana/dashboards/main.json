{
  "dashboard": {
    "title": "Garamatic Overview",
    "tags": ["garamatic"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Prometheus Up",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"prometheus\"}",
            "refId": "A"
          }
        ],
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 }
      },
      {
        "id": 2,
        "title": "Container Count",
        "type": "stat",
        "targets": [
          {
            "expr": "count(container_last_seen)",
            "refId": "A"
          }
        ],
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 }
      }
    ],
    "time": { "from": "now-1h", "to": "now" },
    "schemaVersion": 36
  }
}
