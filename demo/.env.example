# Garamatic Demo Environment Variables
# Copy this to .env and set your actual SendGrid API key

# SendGrid configuration for real email delivery
# Get your API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=support@garamatic.com
SENDGRID_FROM_NAME=Garamatic Support

# Tenant for seeding
TENANT=desgoffe

# Agentic API key
AGENTIC_API_KEY=garamatic-agentic-secret-key

# LLM configuration
LLAMA_BASE_URL=http://llama:8080/v1
LLAMA_API_KEY=sk-llama

# Grafana
GRAFANA_ADMIN_PASSWORD=admin
