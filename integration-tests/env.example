# ═══════════════════════════════════════════════════════════════════════════
# Integration Test Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and customize for your local setup
# ═══════════════════════════════════════════════════════════════════════════

# Service URLs (adjust ports if running services on different ports)
TICKET_MASALA_URL=http://localhost:8085
GATEKEEPER_URL=http://localhost:8086
MAILING_SERVICE_URL=http://localhost:8087
EVENT_PLANNER_URL=http://localhost:8088
MAILHOG_URL=http://localhost:8025
TEST_RECEIVER_URL=http://localhost:8089

# Test Configuration
TEST_TIMEOUT=30000
TEST_RETRIES=3

# Docker Configuration
COMPOSE_PROJECT_NAME=garamatic-integration-tests
