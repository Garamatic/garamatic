# ─── Environment & Secrets ───────────────────────────────────────────────
.env
.env.local
.env.override

# ─── AI Agent Artifacts (Pi, Ralph, etc.) ────────────────────────────────
.pi/
.ralph/
.factory/
.impeccable/

# ─── AI-Generated Design Documents ───────────────────────────────────────
dev-docs/

# ─── Docker ──────────────────────────────────────────────────────────────
.env.override

# ─── IDE ─────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ─── OS ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Logs ────────────────────────────────────────────────────────────────
*.log

# ─── Node.js ─────────────────────────────────────────────────────────────
node_modules/

# ─── Temporary Files ─────────────────────────────────────────────────────
