# ═══════════════════════════════════════════════════════════════════════════
# Garamatic Meta-Repo — .gitignore
# ═══════════════════════════════════════════════════════════════════════════

# ─── Environment & Secrets ───────────────────────────────────────────────
.env
.env.local
.env.override

# ─── Backups ─────────────────────────────────────────────────────────────
backups/

# ─── AI Agent Artifacts (Pi, Ralph, etc.) ────────────────────────────────
.pi/
.ralph/
.factory/
.impeccable/

# ─── AI-Generated Design Documents ───────────────────────────────────────
dev-docs/

# ─── Database Files ─────────────────────────────────────────────────────
*.sqlite
*.db

# ─── IDE ─────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ─── OS ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Logs ────────────────────────────────────────────────────────────────
*.log

# ─── Node.js ─────────────────────────────────────────────────────────────
node_modules/

# ─── Temporary Files ─────────────────────────────────────────────────────
*.tmp
*.temp
*.pyc
__pycache__/
.pytest_cache/
.ruff_cache/
.mypy_cache/


# ─── Cloudflare Tunnel ─────────────────────────────────────────────────────
cloudflared/credentials.json
cloudflared/config.yml

# ─── Integration Test Artifacts ──────────────────────────────────────
integration-tests/test-reports/
integration-tests/test-results/
integration-tests/docker/test-results/
integration-tests/docker/test-logs/
models/
